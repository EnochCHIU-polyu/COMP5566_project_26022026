# Copy this file to .env and fill the values.

# API keys
POE_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
ETHERSCAN_API_KEY=

# LLM settings
DEFAULT_MODEL=deepseek-v3.2
TEMPERATURE=0
MAX_CONTEXT_TOKENS=32000
API_PAUSE_SECONDS=13
CLASSIFICATION_MODE=non_binary
BATCH_VULNS_PER_PROMPT=8
LLM_TRACE_MESSAGES=false
LLM_TRACE_MAX_CHARS=4000
SLITHER_GATE_ENABLED=true
SLITHER_GATE_MODEL=deepseek-v3.2
MAPPING_USE_LLM_JUDGE=false
MAPPING_JUDGE_MODEL=deepseek-v3.2
SHORTLIST_MIN_TYPES=3
SHORTLIST_MAX_TYPES=6
RUNTIME_AUDIT_METRICS_FILE=data/runtime_metrics/audit_metrics.jsonl

# Data backend
DATA_BACKEND=local

# Supabase (required when DATA_BACKEND=supabase)
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_CONTRACTS_TABLE=contracts
SUPABASE_SUBMISSIONS_TABLE=flagged_contract_submissions
SUPABASE_VULNERABILITIES_TABLE=vulnerability_types
SUPABASE_OTHER_VULNERABILITIES_TABLE=vulnerability_types_other_candidates
